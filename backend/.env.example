# ─────────────────────────────────────────────────────────────────────────
# backend/.env — the single source of configuration for this project.
# Copy to backend/.env (`make setup` does this) and fill in your API keys.
#
#   • docker-compose loads this file into the backend container (env_file).
#   • local runs (pytest, `make dev`) read it via app/config.py.
# DATABASE_URL and CORS_ORIGINS are overridden by docker-compose when running
# in Docker, so the values here are only used for local (non-Docker) runs.
# ─────────────────────────────────────────────────────────────────────────

# LLM for essay analysis (required for that feature).
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Server secret to encrypt per-user Mistral keys at rest (any non-empty string,
# e.g. `openssl rand -hex 32`). Required for the personal-cabinet key + the
# server-side vocab enrichment worker. Empty → that feature is disabled.
MISTRAL_KEY_SECRET=

# Local (non-Docker) database. Docker overrides this with PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

CORS_ORIGINS=http://127.0.0.1:8753,http://localhost:8753,http://127.0.0.1:5173
SECURE_COOKIES=false

# Comma-separated accounts that may drive the enrichment fleet from the pipeline
# page (start/stop every account's worker at once, see its token spend). That
# spends OTHER accounts' Mistral keys, so it is deliberately settable here only —
# nothing in the app can grant it. Empty (the default) → nobody is an admin.
# Changing it needs a backend restart, which kills any running worker.
ADMIN_EMAILS=
TOPICS_DIR=./data/topics
