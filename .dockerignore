.git
# Virtualenvs must never leak into the image (they shadow /app/.venv and are huge)
.venv
**/.venv
venv
# Python caches
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
# Local data / secrets
backend/data/*.db
backend/.env
.env
# Assets the backend image doesn't need
*.png
*.jpg
*.pdf
# Big local-only dirs (keep the build context small)
graphify-out
analysis-samples
screenshots
node_modules
dist

# vocab pipeline: big local-only data (mounted at runtime, never baked)
dictionaries
backend/app/vocab/vocab.db
backend/app/vocab/vocab_data
backend/app/vocab/.venv
